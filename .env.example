# ModLens MCP вЂ” environment variables
# Copy this to .env and fill in your values.

# в”Ђв”Ђ Database (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Leave DATABASE_URL unset to use the zero-config embedded SQLite default
# (installed runs bootstrap ~/.modlens/data/modlens.db automatically).
# Set one of the following to choose a backend explicitly:
#   SQLite (embedded, default):  file:./modlens.db
#   PGlite  (embedded Postgres): pglite:///absolute/path/to/data
#   Postgres (Docker/existing):  postgresql://modlens:modlens@localhost:5433/modlens
# DATABASE_URL=file:./modlens.db

# в”Ђв”Ђ Semantic search (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Install Ollama (https://ollama.com) and pull a model:
#   ollama pull nomic-embed-text
# Then set these and run:  npm run db:vector
#                           node dist/cli.js backfill-embeddings --type docs
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Dimension must match the model output. nomic-embed-text = 768.
# If you switch models, drop/re-add the embedding columns and re-run db:vector.
# OLLAMA_EMBED_DIM=768

# в”Ђв”Ђ Platform API keys (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
CURSEFORGE_API_KEY=
MODRINTH_TOKEN=

# в”Ђв”Ђ Cache location (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Where decompiled source, downloaded tools/JARs, and indexes are cached.
# Defaults to ~/.modlens-cache. Override to relocate it вЂ” e.g. onto a persistent,
# writable volume in Docker (the official image sets this to /data/.modlens-cache).
# MODLENS_CACHE_ROOT=

# в”Ђв”Ђ Logging (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Verbose server-side logging: full stack traces + the exact failing tool params
# are printed to stderr instead of only being returned to the model. Auto-enabled
# when running as an HTTP server (MCP_PORT set). Set to 0/false to silence, or to
# 1/true to force it on under stdio.
# MODLENS_VERBOSE=1

# в”Ђв”Ђ Graph extraction (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Backend for Graphify semantic extraction. Auto-detected if unset.
# Values: ollama|gemini|deepseek|openai|claude|kimi|custom|ast-only
# GRAPHIFY_BACKEND=
# GRAPHIFY_MODEL=                # Override model for the chosen backend

# Cloud provider API keys (checked in order: geminiв†’deepseekв†’openaiв†’claudeв†’kimi)
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# KIMI_API_KEY=

# Custom OpenAI-compatible endpoint
# GRAPHIFY_CUSTOM_BASE_URL=
# GRAPHIFY_CUSTOM_API_KEY=
# GRAPHIFY_CUSTOM_MODEL=

# в”Ђв”Ђ Registries (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# URL to pre-built graph registry index.json
MODLENS_GRAPH_REGISTRY_URL=https://raw.githubusercontent.com/Mattabase/modlens-graphs/main/index.json
# URL to pre-computed embedding registry index.json
MODLENS_EMBED_REGISTRY_URL=https://raw.githubusercontent.com/Mattabase/modlens-embeddings/main/index.json
