# ModLens MCP — environment variables
# Copy this to .env and fill in your values.

# ── Database (optional) ───────────────────────────────────────────────────────
# Leave DATABASE_URL unset to use the zero-config embedded SQLite default
# (installed runs bootstrap ~/.modlens/data/modlens.db automatically).
# Set one of the following to choose a backend explicitly:
#   SQLite (embedded, default):  file:./modlens.db
#   PGlite  (embedded Postgres): pglite:///absolute/path/to/data
#   Postgres (Docker/existing):  postgresql://modlens:modlens@localhost:5433/modlens
# DATABASE_URL=file:./modlens.db

# ── Semantic search (optional) ────────────────────────────────────────────────
# Install Ollama (https://ollama.com) and pull a model:
#   ollama pull nomic-embed-text
# Then set these and run:  npm run db:vector
#                           node dist/cli.js backfill-embeddings --type docs
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Dimension must match the model output. nomic-embed-text = 768.
# If you switch models, drop/re-add the embedding columns and re-run db:vector.
# OLLAMA_EMBED_DIM=768

# ── Platform API keys (optional) ─────────────────────────────────────────────
CURSEFORGE_API_KEY=
MODRINTH_TOKEN=

# ── Logging (optional) ────────────────────────────────────────────────────────
# Verbose server-side logging: full stack traces + the exact failing tool params
# are printed to stderr instead of only being returned to the model. Auto-enabled
# when running as an HTTP server (MCP_PORT set). Set to 0/false to silence, or to
# 1/true to force it on under stdio.
# MODLENS_VERBOSE=1

# ── Graph extraction (optional) ──────────────────────────────────────────────
# Backend for Graphify semantic extraction. Auto-detected if unset.
# Values: ollama|gemini|deepseek|openai|claude|kimi|custom|ast-only
# GRAPHIFY_BACKEND=
# GRAPHIFY_MODEL=                # Override model for the chosen backend

# Cloud provider API keys (checked in order: gemini→deepseek→openai→claude→kimi)
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# KIMI_API_KEY=

# Custom OpenAI-compatible endpoint
# GRAPHIFY_CUSTOM_BASE_URL=
# GRAPHIFY_CUSTOM_API_KEY=
# GRAPHIFY_CUSTOM_MODEL=

# ── Registries (optional) ────────────────────────────────────────────────────
# URL to pre-built graph registry index.json
MODLENS_GRAPH_REGISTRY_URL=https://raw.githubusercontent.com/Mattabase/modlens-graphs/main/index.json
# URL to pre-computed embedding registry index.json
MODLENS_EMBED_REGISTRY_URL=https://raw.githubusercontent.com/Mattabase/modlens-embeddings/main/index.json
