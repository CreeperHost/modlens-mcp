# Supply-chain cooldown: when RESOLVING dependency versions (npm install /
# npm update / unpinned ranges), refuse any version published less than 7 days
# ago. Most malicious releases are detected and yanked within hours, so this
# filters smash-and-grab compromises. Requires npm >= 11.17.
#
# npm ci installs the exact versions pinned in package-lock.json — those were
# already age-vetted when they were resolved into the lockfile, so locked
# installs are not blocked. To intentionally add a brand-new dependency, run
# `npm install <pkg> --min-release-age=0` for that one command.
min-release-age=7
